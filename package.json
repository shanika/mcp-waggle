{
  "name": "mcp-waggle",
  "version": "0.2.0",
  "description": "Waggle — MCP server for logging research activities, publishing test results, and tracking project progress",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "waggle": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && rm -rf dist/migrations && cp -R src/db/migrations dist/migrations",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:report": "vitest run --reporter=default --reporter=./scripts/vitest-waggle-reporter.mjs",
    "smoke": "node scripts/smoke.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node dist/index.js migrate",
    "db:seed": "node dist/index.js seed",
    "ui": "node dist/index.js ui",
    "deploy": "./scripts/deploy-pi.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "nanoid": "^5.1.16",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
